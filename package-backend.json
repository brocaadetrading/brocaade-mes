{
  "name": "brocaade-mes-backend",
  "version": "1.0.0",
  "description": "Brocaade Manufacturing Execution System & Interior Project Management Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "db:init": "psql -U postgres -d brocaade_mes -f schema.sql",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "deploy:vercel": "vercel deploy",
    "deploy:render": "render deploy",
    "deploy:heroku": "git push heroku main"
  },
  "keywords": [
    "manufacturing",
    "execution",
    "interior",
    "project-management",
    "express",
    "postgresql",
    "nodejs"
  ],
  "author": "Brocaade",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "pg": "^8.11.1",
    "axios": "^1.5.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0",
    "express-rate-limit": "^7.1.1",
    "express-validator": "^7.0.1",
    "compression": "^1.7.4",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.50.0",
    "prettier": "^3.0.3",
    "@babel/preset-env": "^7.22.20"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/brocaade-mes.git"
  }
}
